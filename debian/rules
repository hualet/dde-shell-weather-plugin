#!/usr/bin/make -f

export DH_VERBOSE = 1
export DEB_BUILD_MAINT_OPTIONS = hardening=+all

DEB_HOST_GNU_TYPE ?= $(shell dpkg-architecture -qDEB_HOST_GNU_TYPE)
DEB_BUILD_GNU_TYPE ?= $(shell dpkg-architecture -qDEB_BUILD_GNU_TYPE)

ifneq ($(DEB_BUILD_GNU_TYPE),$(DEB_HOST_GNU_TYPE))
    export DEB_CXXFLAGS_MAINT_APPEND = -I/usr/include/$(DEB_HOST_GNU_TYPE)
    export DEB_LDFLAGS_MAINT_APPEND = -L/usr/lib/$(DEB_HOST_GNU_TYPE)
    CMAKE_OPTIONS += -DCMAKE_TOOLCHAIN_FILE=/usr/share/cmake/debian-toolchain-file.cmake
endif

%:
	dh $@

override_dh_auto_configure:
	dh_auto_configure -- \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		$(CMAKE_OPTIONS)

override_dh_shlibdeps:
	dh_shlibdeps --dpkg-shlibdeps-params=--ignore-missing-info
